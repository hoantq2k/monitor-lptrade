{
  "annotations": {"list": []},
  "description": "Production overview for the Docker Swarm monitoring stack. Queries use the labels emitted by this repository: service_name, nodename, host_ip, redis_role, target, and cAdvisor Swarm container labels.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(up{job=~\"prometheus|alertmanager|node_exporter|cadvisor|postgres_exporter|redis_exporter|rabbitmq|blackbox_.*\"} == 0)", "legendFormat": "down targets", "refId": "A"}],
      "title": "Targets down",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "legend": {"displayMode": "list", "placement": "bottom"}, "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "count(count by (nodename) (node_uname_info{job=\"node_exporter\",nodename=~\"$host\"}))", "legendFormat": "hosts", "refId": "A"}],
      "title": "Hosts",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"node_exporter\",nodename=~\"$host\"} / node_memory_MemTotal_bytes{job=\"node_exporter\",nodename=~\"$host\"}))", "legendFormat": "{{nodename}} ({{host_ip}})", "refId": "A"}],
      "title": "Host memory usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 4,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "100 * (1 - avg by (nodename, host_ip) (rate(node_cpu_seconds_total{job=\"node_exporter\",mode=\"idle\",nodename=~\"$host\"}[5m])))", "legendFormat": "{{nodename}} ({{host_ip}})", "refId": "A"}],
      "title": "Host CPU usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "100 * sum by (container_label_com_docker_swarm_service_name, nodename) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\",container_label_com_docker_swarm_service_name=~\"$service\",container_label_com_docker_swarm_service_name!=\"\",image!=\"\"}[5m]))", "legendFormat": "{{container_label_com_docker_swarm_service_name}} on {{nodename}}", "refId": "A"}],
      "title": "Swarm service CPU (actual service label)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "max by (container_label_com_docker_swarm_service_name, container_label_com_docker_swarm_task_name, nodename) (container_memory_working_set_bytes{job=\"cadvisor\",container_label_com_docker_swarm_service_name=~\"$service\",container_label_com_docker_swarm_service_name!=\"\",image!=\"\"})", "legendFormat": "{{container_label_com_docker_swarm_service_name}} / {{container_label_com_docker_swarm_task_name}} on {{nodename}}", "refId": "A"}],
      "title": "Container memory (actual Swarm task name)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "probe_duration_seconds{job=~\"blackbox_.*\",target=~\"$target\"}", "legendFormat": "{{job}} / {{service_name}} / {{target}}", "refId": "A"}],
      "title": "Blackbox TCP latency (actual target)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "redis_up{job=\"redis_exporter\",redis_role=~\"$redis_role\"}", "legendFormat": "{{redis_role}} / {{service_name}} on {{nodename}}", "refId": "A"}],
      "title": "Redis exporter status by role",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 9,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "pg_up{job=\"postgres_exporter\"}", "legendFormat": "{{service_name}} on {{nodename}} ({{host_ip}})", "refId": "A"}, {"expr": "up{job=\"rabbitmq\"}", "legendFormat": "{{service_name}} on {{nodename}} ({{host_ip}})", "refId": "B"}],
      "title": "Database and broker exporter status",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docker-swarm", "prometheus", "production", "swarm-monitoring"],
  "templating": {
    "list": [
      {"current": {"text": "Prometheus", "value": "Prometheus"}, "hide": 0, "label": "Datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "type": "datasource"},
      {"allValue": ".*", "current": {"text": "All", "value": ["$__all"]}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(node_uname_info{job=\"node_exporter\"},nodename)", "includeAll": true, "label": "Host (nodename)", "name": "host", "query": {"query": "label_values(node_uname_info{job=\"node_exporter\"},nodename)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"},
      {"allValue": ".*", "current": {"text": "All", "value": ["$__all"]}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(container_cpu_usage_seconds_total{job=\"cadvisor\"},container_label_com_docker_swarm_service_name)", "includeAll": true, "label": "Service", "name": "service", "query": {"query": "label_values(container_cpu_usage_seconds_total{job=\"cadvisor\"},container_label_com_docker_swarm_service_name)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"},
      {"allValue": ".*", "current": {"text": "All", "value": ["$__all"]}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(redis_up{job=\"redis_exporter\"},redis_role)", "includeAll": true, "label": "Redis role", "name": "redis_role", "query": {"query": "label_values(redis_up{job=\"redis_exporter\"},redis_role)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"},
      {"allValue": ".*", "current": {"text": "All", "value": ["$__all"]}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(probe_success{job=~\"blackbox_.*\"},target)", "includeAll": true, "label": "Probe target", "name": "target", "query": {"query": "label_values(probe_success{job=~\"blackbox_.*\"},target)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"}
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Production - Swarm Monitoring Overview",
  "uid": "swarm-monitoring-overview",
  "version": 1
}
