{
  "annotations": {"list": []},
  "description": "RabbitMQ dashboard for the tools_rabbitmq service scraped through the native rabbitmq_prometheus plugin at port 15692.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(up{job=\"rabbitmq\",service_name=\"tools_rabbitmq\"})", "legendFormat": "tools_rabbitmq", "refId": "A"}],
      "title": "RabbitMQ metrics endpoint",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(rabbitmq_queue_messages_ready{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"})", "legendFormat": "ready messages", "refId": "A"}],
      "title": "Messages ready",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(rabbitmq_queue_messages_unacked{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"})", "legendFormat": "unacked messages", "refId": "A"}],
      "title": "Messages unacknowledged",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(rabbitmq_queue_consumers{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"})", "legendFormat": "consumers", "refId": "A"}],
      "title": "Consumers",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (rabbitmq_vhost, rabbitmq_queue) (rabbitmq_queue_messages_ready{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"})", "legendFormat": "{{rabbitmq_vhost}} / {{rabbitmq_queue}}", "refId": "A"}],
      "title": "Queue depth - ready messages",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (rabbitmq_vhost, rabbitmq_queue) (rabbitmq_queue_messages_unacked{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"})", "legendFormat": "{{rabbitmq_vhost}} / {{rabbitmq_queue}}", "refId": "A"}],
      "title": "Queue depth - unacknowledged messages",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (rabbitmq_vhost, rabbitmq_queue) (rabbitmq_queue_consumers{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"})", "legendFormat": "{{rabbitmq_vhost}} / {{rabbitmq_queue}}", "refId": "A"}],
      "title": "Consumers by queue",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (rabbitmq_vhost, rabbitmq_queue) (rabbitmq_queue_messages_ready{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"}) and on (rabbitmq_vhost, rabbitmq_queue) (sum by (rabbitmq_vhost, rabbitmq_queue) (rabbitmq_queue_consumers{job=\"rabbitmq\",rabbitmq_vhost=~\"$vhost\",rabbitmq_queue=~\"$queue\"}) == 0)", "legendFormat": "{{rabbitmq_vhost}} / {{rabbitmq_queue}}", "refId": "A"}],
      "title": "Ready messages with no consumers",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["rabbitmq", "prometheus", "production", "docker-swarm"],
  "templating": {
    "list": [
      {"current": {"text": "Prometheus", "value": "Prometheus"}, "hide": 0, "label": "Datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "type": "datasource"},
      {"allValue": ".*", "current": {"text": "All", "value": ["$__all"]}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(rabbitmq_queue_messages_ready{job=\"rabbitmq\"},rabbitmq_vhost)", "includeAll": true, "label": "VHost", "name": "vhost", "query": {"query": "label_values(rabbitmq_queue_messages_ready{job=\"rabbitmq\"},rabbitmq_vhost)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"},
      {"allValue": ".*", "current": {"text": "All", "value": ["$__all"]}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(rabbitmq_queue_messages_ready{job=\"rabbitmq\"},rabbitmq_queue)", "includeAll": true, "label": "Queue", "name": "queue", "query": {"query": "label_values(rabbitmq_queue_messages_ready{job=\"rabbitmq\"},rabbitmq_queue)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"}
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
